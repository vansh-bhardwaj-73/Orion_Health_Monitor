PORT=5000

# ── IBM Cloudant ──────────────────────────────────────────────────
# Find: IBM Cloud → Resource List → Cloudant → Service Credentials → New Credential
CLOUDANT_PASSWORD=your_cloudant_api_key_here
CLOUDANT_URL=https://your-instance.cloudantnosqldb.appdomain.cloud
CLOUDANT_DB_NAME=orion_db

# ── IBM Watson Assistant (New Experience) ─────────────────────────
# WATSON_ASSISTANT_API_KEY: IBM Cloud → Watson Assistant service → Service Credentials
# WATSON_ASSISTANT_URL:     Service Credentials → url  (base URL, no /instances/ path)
# WATSON_ASSISTANT_ID:      Watson Assistant → Settings → API Details → Assistant ID
# WATSON_ASSISTANT_ENV_ID:  Watson Assistant → Environments → Draft → API Details → Environment ID
WATSON_ASSISTANT_API_KEY=your_watson_api_key_here
WATSON_ASSISTANT_URL=https://api.us-south.assistant.watson.cloud.ibm.com
WATSON_ASSISTANT_ID=your_assistant_id_here
WATSON_ASSISTANT_ENV_ID=your_environment_id_here

# ── Twilio (SMS / WhatsApp) ───────────────────────────────────────
# Find: https://console.twilio.com → Account Info panel
TWILIO_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=+1xxxxxxxxxx
TWILIO_WHATSAPP=whatsapp:+14155238886
